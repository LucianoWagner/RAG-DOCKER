# =============================================================================
# Configuración del Proyecto RAG - Docker Support
# Copiar este archivo a .env y ajustar según necesidad
# =============================================================================

# ==== Modelos Ollama ====
LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

# ==== Puertos (ajustar si hay conflictos) ====
OLLAMA_PORT=11434
CHROMA_PORT=8000
BACKEND_PORT=8080
WEBUI_PORT=3000

# ==== Chunking ====
CHUNK_SIZE=800
CHUNK_OVERLAP=200

# ==== Retrieval ====
TOP_K=10
RERANK_TOP_N=5
SEMANTIC_WEIGHT=0.6
BM25_WEIGHT=0.4

# ==== Evidence Check ====
MIN_TOP_SCORE=0.3
MIN_RELEVANT_CHUNKS=2
RELEVANCE_THRESHOLD=0.25

# ==== ChromaDB ====
CHROMA_COLLECTION_NAME=docker_docs

# ==== Logging ====
LOG_LEVEL=INFO
